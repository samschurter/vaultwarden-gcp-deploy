### GLOBAL VARIABLES ###

# The fully-qualified hostname for Vaultwarden, for example vw.example.com.
# Use the full host name, not just the zone root like example.com unless you intentionally want Vaultwarden there.
# Do not include the protocol (http/https); docker-compose.yml adds that where needed.
# Used for the Caddy proxy and ddclient.
DOMAIN=

# Timezone - used by some containers for logs / cron
# Find your location on this list and use the value in TZ Database Name, e.g Europe/Rome:
#   https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=

# SMTP settings for Vaultwarden and the backup container
# For Google Workspace (recommended): use smtp.gmail.com with an app password.
#   - 2-Step Verification must be enabled on the sending account.
#   - Generate an app password at: https://myaccount.google.com/apppasswords
#   - Use that app password as SMTP_PASSWORD (not your regular account password).
# For other providers see: https://github.com/dani-garcia/vaultwarden/wiki/SMTP-Configuration

# Google Workspace / Gmail defaults — fill in your address and app password:
SMTP_HOST=smtp.gmail.com
SMTP_FROM=you@yourdomain.com
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=you@yourdomain.com
SMTP_PASSWORD=
# msmtpd sidecar for fail2ban email alerts (see docker-compose.yml)
SMTP_TLS=on
SMTP_STARTTLS=on

### VAULTWARDEN VARIABLES ###

# Bootstrap with a one-time admin token and keep public signups closed until you are ready.
# If you later enable signups, Vaultwarden will require e-mail verification and only allow
# addresses from SIGNUPS_DOMAINS_WHITELIST.
SIGNUPS_ALLOWED=false
SIGNUPS_VERIFY=true
SIGNUPS_DOMAINS_WHITELIST=
ADMIN_TOKEN=

## Enables push notifications (requires key and id from https://bitwarden.com/host)
# PUSH_ENABLED=true
# PUSH_INSTALLATION_ID=
# PUSH_INSTALLATION_KEY=
## Don't change this unless you know what you're doing.
# PUSH_RELAY_BASE_URI=https://push.bitwarden.com

# Specify YUBIKEY info if desired
#YUBICO_CLIENT_ID=
#YUBICO_SECRET_KEY=
#YUBICO_SERVER=

# Specfiy which user email addresses can create organizations
# Leave blank to allow all users
ORG_CREATION_USERS=

# Vaultwarden Backup Options
#
#
# GENERAL OPTIONS:
#
# How often to run the backup script; default is daily at midnight
BACKUP_SCHEDULE=0 0 * * *
# How many days of backups to keep
BACKUP_DAYS=30
# Directory to place backups in (& sync from in rclone)
BACKUP_DIR=/data/backups
# Optional - encryption key for backup
#   when set, backup archives are encrypted with openssl before storage or upload
#BACKUP_ENCRYPTION_KEY="<key to encrypt backup>"
# Email address to send backup (BACKUP=email) or notifications (BACKUP_NOTIFY=true)
BACKUP_EMAIL_TO="<email to send the backup to>"
# Send email notification for rclone|local backup jobs
BACKUP_EMAIL_NOTIFY=true
#
#
# Managed deployment always syncs backups to GCS with rclone.
# Manual or legacy deployments can still add other modes if needed.
BACKUP=rclone
#
# RCLONE BACKUP OPTIONS:
#
# For the managed GCP deployment, bootstrap.sh creates an rclone remote named `gcs`
# automatically when BACKUP includes rclone. In that flow, set BACKUP_RCLONE_DEST to the
# bucket/path only, for example: your-project-id-vaultwarden-backups/vaultwarden
# Do not include the remote name prefix here; backup.sh prepends the configured remote for you.
# Manual or legacy deployments may use a different remote name, but the same rule applies:
# BACKUP_RCLONE_DEST is the path inside the remote, not remote:path.
BACKUP_RCLONE_CONF=/data/rclone/rclone.conf
BACKUP_RCLONE_DEST=your-project-id-vaultwarden-backups/vaultwarden


### PROXY / CADDY VARIABLES ###

# EMAIL address to use with Let's Encrypt certificate provisioning
EMAIL=


### DDNS VARIABLES ###

# These variables are only necessary if you are using ddclient.
# The linuxserver/ddclient image uses them to decide which UID and GID should own files under /config.
# In the managed GCP deployment, fetch-secrets.sh writes ddns/ddclient.conf as root on the host,
# so PUID=0 and PGID=0 are the correct values and are set automatically by create-gcp-secrets.sh.
# For a manual deployment on a different host, set these to the UID and GID that should own ddns/.
# ddclient config bind path used by docker-compose.yml.
VWGC_DDCLIENT_CONF=./ddns/ddclient.conf
PUID=
# Group ID paired with PUID.
PGID=


### COUNTRY BLOCKING VARIABLES ###

# Country allowlist using ISO 3166-1 alpha-2 codes (https://en.wikipedia.org/wiki/ISO_3166-1_alpha-2)
# Only listed countries are allowed to reach the host from the public internet.
# Treat this as defense in depth around public ingress, not the primary security boundary.
# Default is US for the managed deployment. Add more countries only if you expect legitimate users there.
# Data is pulled from www.ipdeny.com. The feed's MD5 manifest is useful for basic transfer integrity,
# but it is not an independent security guarantee because the manifest and zone files share the same origin.
# Example: COUNTRIES=US CA
COUNTRIES=US

# How often to update the ip block list - default is daily at midnight; see https://en.wikipedia.org/wiki/Cron#CRON_expression
COUNTRYBLOCK_SCHEDULE=0 0 * * *


### WATCHTOWER VARIABLES ###

# How often should watchtower check for updated container images? Default is every Sunday at 3am
WATCHTOWER_SCHEDULE=0 0 3 ? * 0
